# ── Tinkoff Invest API ──────────────────────────────────────────────────────
# Get token at: https://www.tinkoff.ru/invest/settings/api/
T_INVEST_TOKEN=your_tinkoff_invest_token_here
T_INVEST_ACCOUNT_ID=your_account_id_here

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Create a bot via @BotFather and get the chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Trading mode ─────────────────────────────────────────────────────────────
# autonomous | manual
MODE=autonomous

# ── Risk limits ──────────────────────────────────────────────────────────────
MAX_POSITIONS=3
MAX_POSITION_PCT=0.1
MAX_PORTFOLIO_RISK_PCT=0.01
MAX_DAILY_LOSS_PCT=0.015
MAX_DRAWDOWN_PCT=0.06

# ── Kelly & sizing ───────────────────────────────────────────────────────────
KELLY_FRACTION=0.25

# ── Signal thresholds ────────────────────────────────────────────────────────
SIGNAL_THRESHOLD=0.65
SPREAD_THRESHOLD=1.5

# ── Scanning ─────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=60
ML_LOOKBACK_DAYS=180

# ── Strategy toggles ─────────────────────────────────────────────────────────
INCLUDE_FUTURES=true
ALLOW_SHORTS=true
USE_LEVERAGE=false
MAX_LEVERAGE=2.0
ACTIVE_PROFILE=conservative

# ── Order execution ──────────────────────────────────────────────────────────
ORDER_EXECUTION_MODE=limit_aggressive
LIMIT_ORDER_TIMEOUT=45
LIMIT_ORDER_RETRY_MARKET=true

# ── ATR-based stop/target ────────────────────────────────────────────────────
STOP_ATR_MULT=4.0
TARGET_ATR_MULT=2.0

# ── Misc ─────────────────────────────────────────────────────────────────────
PORTFOLIO_CHECK_MINUTES=5
LONG_AUTO_PAUSE=false
MIN_TARGET_PROGRESS_FRAC=0.0
